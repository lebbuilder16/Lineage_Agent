# Dockerfile.fly – Fly.io backend-only image
#
# This is a single-stage build for the FastAPI backend,
# designed specifically for Fly.io deployment.

FROM python:3.12-slim

WORKDIR /app

# Install build deps, compile Python packages, then drop the compiler to keep the image lean
COPY requirements.txt .
RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc libjpeg62-turbo-dev zlib1g-dev && \
    pip install --no-cache-dir -r requirements.txt && \
    apt-get purge -y --auto-remove gcc && \
    rm -rf /var/lib/apt/lists/*

COPY src/ ./src/
COPY skills/ ./skills/

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src

# Run as non-root user for security
RUN useradd --create-home --shell /bin/bash appuser && \
    mkdir -p /data && chown -R appuser:appuser /app /data
USER appuser

EXPOSE 8080

CMD ["sh", "-c", "uvicorn lineage_agent.api:app --host 0.0.0.0 --port 8080 --workers ${UVICORN_WORKERS:-1}"]
