{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": [
      "jest"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@/theme": [
        "src/theme/tokens"
      ],
      "@/types": [
        "src/types/api"
      ],
      "@/lib/*": [
        "src/lib/*"
      ],
      "@/store/*": [
        "src/store/*"
      ],
      "@/components/*": [
        "src/components/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
