# ── Mobile App Environment Variables ──────────────────────────────────────────
# Copier ce fichier en ".env.local" et remplir les valeurs.
# Les variables préfixées EXPO_PUBLIC_ sont embarquées dans l'APK/AAB (visibles publiquement).
# Ne jamais committer .env.local dans git.

# ── Backend API ───────────────────────────────────────────────────────────────
# URL du backend FastAPI (Fly.io en prod, localhost en dev via tunnel)
EXPO_PUBLIC_API_URL=https://lineage-agent.fly.dev
# Dev local avec tunnel ngrok:
# EXPO_PUBLIC_API_URL=https://xxxx.ngrok-free.app

# ── Privy Auth ────────────────────────────────────────────────────────────────
# App ID depuis https://console.privy.io — visible dans les logs, sans risque
EXPO_PUBLIC_PRIVY_APP_ID=

# ── EAS Build (Expo Application Services) ────────────────────────────────────
# Project ID depuis https://expo.dev — récupérer via: npx eas init
EXPO_PUBLIC_EAS_PROJECT_ID=

# ── Firebase (Android Push Notifications) ────────────────────────────────────
# Fichier google-services.json à placer dans mobile/ (NE PAS COMMITTER)
# Télécharger depuis https://console.firebase.google.com → Paramètres du projet → Android

# ── RevenueCat (In-App Purchases) — optionnel ─────────────────────────────────
# Clé publique depuis https://app.revenuecat.com
# EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
