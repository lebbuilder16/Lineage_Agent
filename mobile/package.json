{
  "name": "lineage-agent-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest --watchAll=false"
  },
  "dependencies": {
    "@ethersproject/shims": "^5.8.0",
    "@expo-google-fonts/inter": "^0.3.0",
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.1.1",
    "@privy-io/expo": "^0.7.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "^8.3.0",
    "@tanstack/react-query": "^5.62.0",
    "expo": "~54.0.0",
    "expo-application": "~7.0.8",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-flash-message": "^0.4.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-purchases": "^8.9.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.15.0",
    "react-native-worklets": "^0.5.1",
    "tailwindcss": "^3.4.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@privy-io|react-native-purchases|nativewind)"
    ],
    "moduleNameMapper": {
      "^@/components/(.*)$": "<rootDir>/src/components/$1",
      "^@/hooks/(.*)$": "<rootDir>/src/hooks/$1",
      "^@/lib/(.*)$": "<rootDir>/src/lib/$1",
      "^@/store/(.*)$": "<rootDir>/src/store/$1",
      "^@/theme/(.*)$": "<rootDir>/src/theme/$1",
      "^@/types/(.*)$": "<rootDir>/src/types/$1",
      "^@/(.*)$": "<rootDir>/$1"
    },
    "setupFilesAfterEnv": []
  },
  "private": true
}
