{
  "expo": {
    "name": "Lineage Agent",
    "slug": "lineage-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lineage",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lineageagent.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to unlock the app securely"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.lineageagent.mobile",
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#00FF9D",
          "defaultChannel": "alerts"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0F",
          "image": "./assets/images/splash.png",
          "imageWidth": 200
        }
      ],
      "expo-web-browser",
      [
        "@sentry/react-native",
        {
          "organization": "YOUR_SENTRY_ORG_SLUG",
          "project": "YOUR_SENTRY_PROJECT_SLUG"
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/7e3aa1cf-5f84-4c9b-8afe-66bce3a21a18"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "7e3aa1cf-5f84-4c9b-8afe-66bce3a21a18"
      },
      "router": {}
    },
    "owner": "leb16"
  }
}
